---
import Layout from '../layouts/Layout.astro';

const values = [
  {
    icon: '🎯',
    title: 'Integridad',
    desc: 'Actuamos con transparencia y honestidad en cada operación.',
  },
  {
    icon: '🤝',
    title: 'Compromiso',
    desc: 'Nos comprometemos con la satisfacción total de nuestros clientes.',
  },
  {
    icon: '💡',
    title: 'Innovación',
    desc: 'Buscamos constantemente nuevas formas de mejorar nuestros servicios.',
  },
  {
    icon: '⭐',
    title: 'Excelencia',
    desc: 'La calidad es nuestro estándar mínimo en cada proyecto.',
  },
  {
    icon: '🌱',
    title: 'Sostenibilidad',
    desc: 'Desarrollamos proyectos responsables con el medio ambiente.',
  },
  {
    icon: '👥',
    title: 'Trabajo en Equipo',
    desc: 'Colaboramos para lograr los mejores resultados para nuestros clientes.',
  },
];

const timeline = [
  { year: '2014', event: 'Fundación de Dharsain Inmobiliaria en Lima.' },
  { year: '2016', event: 'Primer proyecto residencial completado con éxito.' },
  { year: '2018', event: 'Expansión a nuevas zonas de Lima Metropolitana.' },
  { year: '2020', event: 'Más de 300 familias satisfechas en nuestros proyectos.' },
  { year: '2023', event: 'Lanzamiento de la plataforma digital de terrenos.' },
  { year: '2026', event: 'Residencial Dharsain: nuestro proyecto más ambicioso.' },
];
---

<Layout
  title="Nosotros — Dharsain Inmobiliaria"
  description="Conoce la misión, visión y valores de Dharsain Inmobiliaria. Más de 12 años de experiencia en el mercado inmobiliario de Lima."
>
  <section class="page-hero">
    <div class="page-hero__overlay"></div>
    <div class="container page-hero__content">
      <span class="hero__badge">Nuestra Historia</span>
      <h1>Sobre Nosotros</h1>
      <p>Más de 12 años construyendo sueños y creando valor para nuestros clientes e inversionistas.</p>
    </div>
  </section>

  <!-- MISSION / VISION -->
  <section class="section">
    <div class="container">
      <div class="mv-grid">
        <div class="mv-card">
          <div class="mv-card__accent"></div>
          <div class="mv-card__content">
            <span class="mv-icon">🎯</span>
            <h2>Misión</h2>
            <p>
              Brindar soluciones inmobiliarias integrales que permitan a nuestros clientes
              acceder a propiedades de calidad en ubicaciones estratégicas de Lima,
              con financiamiento accesible y un servicio personalizado que supere
              sus expectativas en cada etapa del proceso.
            </p>
          </div>
        </div>
        <div class="mv-card">
          <div class="mv-card__accent"></div>
          <div class="mv-card__content">
            <span class="mv-icon">🔭</span>
            <h2>Visión</h2>
            <p>
              Ser la inmobiliaria líder y más confiable del Perú, reconocida por la
              calidad de nuestros proyectos, la innovación en nuestros servicios y
              el impacto positivo en las comunidades donde operamos,
              contribuyendo al desarrollo urbano sostenible del país.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- VALUES -->
  <section class="section" style="background: var(--color-bg-alt);">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Nuestros Valores</span>
        <h2>Lo que nos define</h2>
        <p>Los principios que guían cada decisión y acción en Dharsain Inmobiliaria.</p>
      </div>
      <div class="values-grid">
        {values.map(v => (
          <div class="value-card">
            <span class="value-icon">{v.icon}</span>
            <h3>{v.title}</h3>
            <p>{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TIMELINE -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Nuestra Trayectoria</span>
        <h2>Hitos en nuestra historia</h2>
      </div>
      <div class="timeline">
        {timeline.map((item, i) => (
          <div class:list={['timeline-item', { 'timeline-item--right': i % 2 !== 0 }]}>
            <div class="timeline-item__dot"></div>
            <div class="timeline-item__content">
              <span class="timeline-year">{item.year}</span>
              <p>{item.event}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TEAM -->
  <section class="section" style="background: var(--color-bg-alt);">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Equipo</span>
        <h2>Nuestro equipo directivo</h2>
        <p>Profesionales con amplia experiencia en el sector inmobiliario.</p>
      </div>
      <div class="team-grid">
        <div class="team-card">
          <div class="team-card__image">
            <img
              src="https://images.unsplash.com/photo-1560250097-0b93528c311a?w=300&h=300&fit=crop"
              alt="Director General"
              loading="lazy"
            />
          </div>
          <h3>Carlos Dharsain</h3>
          <p class="team-role">Director General</p>
        </div>
        <div class="team-card">
          <div class="team-card__image">
            <img
              src="https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?w=300&h=300&fit=crop"
              alt="Directora Comercial"
              loading="lazy"
            />
          </div>
          <h3>María López</h3>
          <p class="team-role">Directora Comercial</p>
        </div>
        <div class="team-card">
          <div class="team-card__image">
            <img
              src="https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?w=300&h=300&fit=crop"
              alt="Director de Proyectos"
              loading="lazy"
            />
          </div>
          <h3>Roberto García</h3>
          <p class="team-role">Director de Proyectos</p>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container cta-content">
      <h2>¿Quieres ser parte de nuestra historia?</h2>
      <p>Únete a las más de 500 familias que ya confiaron en nosotros.</p>
      <a href="/#contacto" class="btn btn-primary">Contáctanos</a>
    </div>
  </section>
</Layout>

<style>
  .page-hero {
    position: relative;
    padding: calc(var(--header-height) + 60px) 0 80px;
    background-image: url('https://images.unsplash.com/photo-1497366216548-37526070297c?w=1600&h=600&fit=crop');
    background-size: cover;
    background-position: center;
    text-align: center;
  }
  .page-hero__overlay { position: absolute; inset: 0; background: linear-gradient(135deg, rgba(15,26,46,0.92), rgba(26,39,68,0.88)); }
  .page-hero__content { position: relative; z-index: 2; }
  .page-hero h1 { color: #fff; margin-bottom: var(--space-md); }
  .page-hero p { color: rgba(255,255,255,0.7); font-size: 1.1rem; max-width: 600px; margin: 0 auto; }
  .hero__badge { display: inline-block; padding: 8px 20px; background: rgba(200,150,78,0.2); border: 1px solid rgba(200,150,78,0.4); border-radius: var(--radius-full); color: var(--color-accent-light); font-size: 0.85rem; font-weight: 600; margin-bottom: var(--space-lg); }
  .section-tag { display: inline-block; padding: 6px 16px; background: rgba(200,150,78,0.12); color: var(--color-accent-dark); border-radius: var(--radius-full); font-size: 0.8rem; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase; margin-bottom: var(--space-md); }

  /* Mission / Vision */
  .mv-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-xl); }
  .mv-card { background: var(--color-surface); border-radius: var(--radius-md); overflow: hidden; box-shadow: var(--shadow-md); display: flex; }
  .mv-card__accent { width: 6px; background: linear-gradient(to bottom, var(--color-accent), var(--color-accent-dark)); flex-shrink: 0; }
  .mv-card__content { padding: var(--space-2xl); }
  .mv-icon { font-size: 2rem; display: block; margin-bottom: var(--space-md); }
  .mv-card h2 { font-size: 1.5rem; margin-bottom: var(--space-md); }
  .mv-card p { font-size: 1rem; line-height: 1.8; margin-bottom: 0; }

  /* Values */
  .values-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-xl); }
  .value-card { text-align: center; padding: var(--space-2xl); background: var(--color-surface); border-radius: var(--radius-md); border: 1px solid var(--color-border); transition: all var(--transition-base); }
  .value-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg); }
  .value-icon { font-size: 2rem; display: block; margin-bottom: var(--space-md); }
  .value-card h3 { font-family: var(--font-body); font-size: 1.1rem; font-weight: 700; margin-bottom: var(--space-sm); }
  .value-card p { font-size: 0.9rem; margin-bottom: 0; }

  /* Timeline */
  .timeline { position: relative; max-width: 700px; margin: 0 auto; padding-left: 40px; }
  .timeline::before { content: ''; position: absolute; left: 15px; top: 0; bottom: 0; width: 2px; background: var(--color-border); }
  .timeline-item { position: relative; margin-bottom: var(--space-xl); }
  .timeline-item__dot { position: absolute; left: -33px; top: 4px; width: 14px; height: 14px; background: var(--color-accent); border-radius: 50%; border: 3px solid var(--color-bg); z-index: 1; }
  .timeline-item__content { background: var(--color-surface); padding: var(--space-lg); border-radius: var(--radius-sm); box-shadow: var(--shadow-sm); border: 1px solid var(--color-border); }
  .timeline-year { font-family: var(--font-heading); font-size: 1.2rem; font-weight: 700; color: var(--color-accent); display: block; margin-bottom: 4px; }
  .timeline-item__content p { margin-bottom: 0; font-size: 0.95rem; }

  /* Team */
  .team-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-xl); max-width: 800px; margin: 0 auto; }
  .team-card { text-align: center; }
  .team-card__image { width: 150px; height: 150px; border-radius: 50%; overflow: hidden; margin: 0 auto var(--space-md); border: 4px solid var(--color-accent); }
  .team-card__image img { width: 100%; height: 100%; object-fit: cover; }
  .team-card h3 { font-family: var(--font-body); font-size: 1.1rem; font-weight: 700; margin-bottom: 4px; }
  .team-role { font-size: 0.9rem; color: var(--color-accent); font-weight: 500; margin-bottom: 0; }

  /* CTA */
  .cta-section { background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light)); padding: var(--space-4xl) 0; text-align: center; }
  .cta-content h2 { color: #fff; margin-bottom: var(--space-md); }
  .cta-content p { color: rgba(255,255,255,0.7); font-size: 1.1rem; margin-bottom: var(--space-xl); }

  @media (max-width: 768px) {
    .mv-grid { grid-template-columns: 1fr; }
    .values-grid { grid-template-columns: 1fr; max-width: 400px; margin: 0 auto; }
    .team-grid { grid-template-columns: 1fr; max-width: 300px; }
  }
</style>
