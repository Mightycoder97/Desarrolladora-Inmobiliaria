---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Dharsain Inmobiliaria — Tu inversión segura en Lima">

  <!-- HERO SECTION -->
  <section class="hero" id="hero">
    <div class="hero__overlay"></div>
    <div class="hero__content container">
      <span class="hero__badge">Proyecto Exclusivo en Lima</span>
      <h1>Tu próximo hogar comienza aquí</h1>
      <p class="hero__subtitle">
        Descubre proyectos inmobiliarios diseñados para tu estilo de vida.
        Financiamiento flexible, ubicaciones premium y asesoría personalizada.
      </p>
      <div class="hero__actions">
        <a href="/proyecto" class="btn btn-primary">Ver Proyecto</a>
        <a href="#contacto" class="btn btn-secondary">Solicitar Información</a>
      </div>
    </div>
    <div class="hero__scroll">
      <span>Descubre más</span>
      <div class="scroll-indicator">
        <div class="scroll-dot"></div>
      </div>
    </div>
  </section>

  <!-- STATS SECTION -->
  <section class="stats section">
    <div class="container stats__grid">
      <div class="stat-item">
        <span class="stat-number" data-target="150">0</span>
        <span class="stat-suffix">+</span>
        <p class="stat-label">Lotes Disponibles</p>
      </div>
      <div class="stat-item">
        <span class="stat-number" data-target="95">0</span>
        <span class="stat-suffix">%</span>
        <p class="stat-label">Clientes Satisfechos</p>
      </div>
      <div class="stat-item">
        <span class="stat-number" data-target="12">0</span>
        <span class="stat-suffix"></span>
        <p class="stat-label">Años de Experiencia</p>
      </div>
      <div class="stat-item">
        <span class="stat-number" data-target="500">0</span>
        <span class="stat-suffix">+</span>
        <p class="stat-label">Familias Felices</p>
      </div>
    </div>
  </section>

  <!-- ABOUT PREVIEW -->
  <section class="about-preview section">
    <div class="container about-preview__grid">
      <div class="about-preview__image">
        <img
          src="https://images.unsplash.com/photo-1560518883-ce09059eeffa?w=600&h=700&fit=crop"
          alt="Proyecto inmobiliario moderno en Lima"
          loading="lazy"
        />
        <div class="about-preview__badge">
          <span class="badge-number">12+</span>
          <span class="badge-text">Años de<br/>Experiencia</span>
        </div>
      </div>
      <div class="about-preview__content">
        <span class="section-tag">Sobre Nosotros</span>
        <h2>Construimos el futuro, un hogar a la vez</h2>
        <p>
          En <strong>Dharsain Inmobiliaria</strong>, nos especializamos en desarrollar proyectos
          inmobiliarios que combinan calidad, ubicación estratégica y precios accesibles para
          el mercado limeño.
        </p>
        <p>
          Nuestra misión es hacer realidad el sueño de la casa propia, brindando opciones
          de financiamiento flexible y un acompañamiento profesional en cada paso del proceso.
        </p>
        <div class="about-features">
          <div class="about-feature">
            <div class="feature-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            </div>
            <div>
              <h4>Proyectos Premium</h4>
              <p>Ubicaciones estratégicas con máxima plusvalía</p>
            </div>
          </div>
          <div class="about-feature">
            <div class="feature-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/></svg>
            </div>
            <div>
              <h4>Inversión Segura</h4>
              <p>Documentación 100% en regla y saneada</p>
            </div>
          </div>
        </div>
        <a href="/nosotros" class="btn btn-outline" style="margin-top: 1.5rem;">Conócenos</a>
      </div>
    </div>
  </section>

  <!-- PROJECT PREVIEW -->
  <section class="project-preview section" id="proyecto">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Proyecto Estrella</span>
        <h2>Residencial Dharsain</h2>
        <p>Un exclusivo proyecto residencial en una de las zonas con mayor crecimiento de Lima.</p>
      </div>
      <div class="project-preview__grid">
        <div class="project-card project-card--main">
          <img
            src="https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=800&h=500&fit=crop"
            alt="Vista aérea del proyecto residencial"
            loading="lazy"
          />
          <div class="project-card__overlay">
            <span class="project-card__tag">Nuevo Lanzamiento</span>
            <h3>Vista panorámica del proyecto</h3>
          </div>
        </div>
        <div class="project-card">
          <img
            src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=400&h=300&fit=crop"
            alt="Interior moderno de departamento"
            loading="lazy"
          />
          <div class="project-card__overlay">
            <h3>Diseños modernos</h3>
          </div>
        </div>
        <div class="project-card">
          <img
            src="https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?w=400&h=300&fit=crop"
            alt="Áreas verdes del proyecto"
            loading="lazy"
          />
          <div class="project-card__overlay">
            <h3>Áreas verdes</h3>
          </div>
        </div>
      </div>
      <div style="text-align: center; margin-top: 2.5rem;">
        <a href="/proyecto" class="btn btn-primary">Ver detalles del proyecto</a>
      </div>
    </div>
  </section>

  <!-- SERVICES SECTION -->
  <section class="services section" id="servicios">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Nuestros Servicios</span>
        <h2>Soluciones integrales para tu inversión</h2>
        <p>Más que una inmobiliaria, somos tu aliado estratégico en el sector inmobiliario.</p>
      </div>
      <div class="services__grid">
        <a href="/servicios" class="service-card">
          <div class="service-card__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          </div>
          <h3>Servicios Inmobiliarios</h3>
          <p>Asesoría completa en compra, venta y administración de propiedades en Lima.</p>
          <span class="service-card__link">Más información →</span>
        </a>
        <a href="/terrenos" class="service-card">
          <div class="service-card__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          </div>
          <h3>Búsqueda de Terrenos</h3>
          <p>Te ayudamos a encontrar el terreno perfecto según tu presupuesto y necesidades.</p>
          <span class="service-card__link">Explorar terrenos →</span>
        </a>
        <a href="/inversionistas" class="service-card">
          <div class="service-card__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" x2="12" y1="2" y2="22"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
          </div>
          <h3>Oportunidades de Inversión</h3>
          <p>Multiplica tu capital con proyectos de alta rentabilidad y retorno garantizado.</p>
          <span class="service-card__link">Invertir ahora →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- PRICING PREVIEW -->
  <section class="pricing-preview section" id="precios">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Precios y Financiamiento</span>
        <h2>Planes a tu medida</h2>
        <p>Opciones flexibles de financiamiento para que puedas adquirir tu terreno ideal.</p>
      </div>
      <div class="pricing__grid">
        <div class="pricing-card">
          <div class="pricing-card__header">
            <h3>Lote Estándar</h3>
            <p class="pricing-area">90 m²</p>
          </div>
          <div class="pricing-card__price">
            <span class="currency">S/</span>
            <span class="amount">85,000</span>
          </div>
          <ul class="pricing-card__features">
            <li>✓ Título de propiedad</li>
            <li>✓ Servicios básicos incluidos</li>
            <li>✓ Acceso a áreas comunes</li>
            <li>✓ Cuota inicial desde 10%</li>
            <li>✓ Hasta 36 meses sin intereses</li>
          </ul>
          <a href="#contacto" class="btn btn-outline" style="width:100%;">Solicitar información</a>
        </div>
        <div class="pricing-card pricing-card--featured">
          <div class="pricing-card__badge">Más Popular</div>
          <div class="pricing-card__header">
            <h3>Lote Premium</h3>
            <p class="pricing-area">120 m²</p>
          </div>
          <div class="pricing-card__price">
            <span class="currency">S/</span>
            <span class="amount">125,000</span>
          </div>
          <ul class="pricing-card__features">
            <li>✓ Título de propiedad</li>
            <li>✓ Servicios completos</li>
            <li>✓ Áreas verdes y parques</li>
            <li>✓ Cuota inicial desde 8%</li>
            <li>✓ Hasta 48 meses sin intereses</li>
            <li>✓ Seguro de inversión</li>
          </ul>
          <a href="#contacto" class="btn btn-primary" style="width:100%;">Reservar ahora</a>
        </div>
        <div class="pricing-card">
          <div class="pricing-card__header">
            <h3>Lote Exclusivo</h3>
            <p class="pricing-area">200 m²</p>
          </div>
          <div class="pricing-card__price">
            <span class="currency">S/</span>
            <span class="amount">195,000</span>
          </div>
          <ul class="pricing-card__features">
            <li>✓ Título de propiedad</li>
            <li>✓ Servicios premium</li>
            <li>✓ Ubicación privilegiada</li>
            <li>✓ Sin cuota inicial</li>
            <li>✓ Hasta 60 meses de financiamiento</li>
            <li>✓ Asesoría legal incluida</li>
          </ul>
          <a href="#contacto" class="btn btn-outline" style="width:100%;">Solicitar información</a>
        </div>
      </div>
    </div>
  </section>

  <!-- CONTACT FORM -->
  <section class="contact section" id="contacto">
    <div class="container">
      <div class="contact__grid">
        <div class="contact__info">
          <span class="section-tag">Contacto</span>
          <h2>¿Listo para invertir en tu futuro?</h2>
          <p>
            Completa el formulario y uno de nuestros asesores se comunicará contigo
            en las próximas 24 horas para brindarte toda la información que necesitas.
          </p>
          <div class="contact__details">
            <div class="contact-detail">
              <div class="contact-detail__icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              </div>
              <div>
                <h4>Teléfono</h4>
                <p>+51 999 999 999</p>
              </div>
            </div>
            <div class="contact-detail">
              <div class="contact-detail__icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              </div>
              <div>
                <h4>Email</h4>
                <p>contacto@dharsain.com</p>
              </div>
            </div>
            <div class="contact-detail">
              <div class="contact-detail__icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <div>
                <h4>Oficina</h4>
                <p>Lima, Perú</p>
              </div>
            </div>
          </div>
        </div>
        <div class="contact__form-wrapper">
          <form class="contact-form" id="contact-form">
            <div class="form-row">
              <div class="form-group">
                <label for="contact-name">Nombre completo</label>
                <input type="text" id="contact-name" class="form-control" placeholder="Juan Pérez" required />
              </div>
              <div class="form-group">
                <label for="contact-phone">Teléfono</label>
                <input type="tel" id="contact-phone" class="form-control" placeholder="+51 999 999 999" required />
              </div>
            </div>
            <div class="form-group">
              <label for="contact-email">Email</label>
              <input type="email" id="contact-email" class="form-control" placeholder="juan@email.com" required />
            </div>
            <div class="form-group">
              <label for="contact-interest">Interesado en</label>
              <select id="contact-interest" class="form-control" required>
                <option value="">Selecciona una opción</option>
                <option value="proyecto">Proyecto Residencial</option>
                <option value="terreno">Búsqueda de Terreno</option>
                <option value="inversion">Oportunidad de Inversión</option>
                <option value="servicios">Servicios Inmobiliarios</option>
                <option value="otro">Otro</option>
              </select>
            </div>
            <div class="form-group">
              <label for="contact-message">Mensaje</label>
              <textarea id="contact-message" class="form-control" placeholder="Cuéntanos sobre lo que buscas..." rows="4"></textarea>
            </div>
            <button type="submit" class="btn btn-primary" style="width: 100%;" id="contact-submit">
              Enviar Mensaje
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ---- HERO ---- */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background-image: url('https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=1600&h=900&fit=crop');
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
    overflow: hidden;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(15, 26, 46, 0.92) 0%,
      rgba(26, 39, 68, 0.85) 50%,
      rgba(42, 63, 106, 0.78) 100%
    );
  }

  .hero__content {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 800px;
    animation: fadeInUp 1s ease-out;
  }

  .hero__badge {
    display: inline-block;
    padding: 8px 20px;
    background: rgba(200, 150, 78, 0.2);
    border: 1px solid rgba(200, 150, 78, 0.4);
    border-radius: var(--radius-full);
    color: var(--color-accent-light);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-xl);
  }

  .hero h1 {
    color: #fff;
    margin-bottom: var(--space-lg);
    font-size: clamp(2.5rem, 6vw, 4rem);
  }

  .hero__subtitle {
    color: rgba(255,255,255,0.75);
    font-size: 1.15rem;
    line-height: 1.8;
    max-width: 600px;
    margin: 0 auto var(--space-2xl);
  }

  .hero__actions {
    display: flex;
    gap: var(--space-md);
    justify-content: center;
    flex-wrap: wrap;
  }

  .hero__scroll {
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    color: rgba(255,255,255,0.5);
    font-size: 0.8rem;
  }

  .scroll-indicator {
    width: 24px;
    height: 40px;
    border: 2px solid rgba(255,255,255,0.3);
    border-radius: 12px;
    display: flex;
    justify-content: center;
    padding-top: 8px;
  }

  .scroll-dot {
    width: 4px;
    height: 8px;
    background: rgba(255,255,255,0.6);
    border-radius: 2px;
    animation: scrollBounce 2s infinite;
  }

  @keyframes scrollBounce {
    0%, 100% { transform: translateY(0); opacity: 1; }
    50% { transform: translateY(12px); opacity: 0.3; }
  }

  /* ---- STATS ---- */
  .stats {
    background: var(--color-primary);
    padding: var(--space-3xl) 0;
    margin-top: -2px;
  }

  .stats__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-xl);
    text-align: center;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .stat-number {
    font-family: var(--font-heading);
    font-size: 3rem;
    font-weight: 700;
    color: var(--color-accent);
    line-height: 1;
  }

  .stat-suffix {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-accent);
    display: inline;
  }

  .stat-label {
    color: rgba(255,255,255,0.7);
    font-size: 0.9rem;
    margin-top: var(--space-sm);
  }

  /* ---- ABOUT PREVIEW ---- */
  .about-preview__grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: var(--space-4xl);
    align-items: center;
  }

  .about-preview__image {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .about-preview__image img {
    width: 100%;
    height: 500px;
    object-fit: cover;
    border-radius: var(--radius-lg);
  }

  .about-preview__badge {
    position: absolute;
    bottom: 24px;
    right: -20px;
    background: var(--color-accent);
    color: #fff;
    padding: 20px 28px;
    border-radius: var(--radius-md);
    text-align: center;
    box-shadow: var(--shadow-lg);
  }

  .badge-number {
    display: block;
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 700;
    line-height: 1;
  }

  .badge-text {
    font-size: 0.75rem;
    font-weight: 500;
    line-height: 1.3;
    opacity: 0.9;
  }

  .section-tag {
    display: inline-block;
    padding: 6px 16px;
    background: rgba(200, 150, 78, 0.12);
    color: var(--color-accent-dark);
    border-radius: var(--radius-full);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: var(--space-md);
  }

  .about-preview__content h2 {
    margin-bottom: var(--space-lg);
  }

  .about-preview__content p {
    font-size: 1.05rem;
    line-height: 1.8;
  }

  .about-features {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    margin-top: var(--space-xl);
  }

  .about-feature {
    display: flex;
    gap: var(--space-md);
    align-items: flex-start;
  }

  .feature-icon {
    width: 48px;
    height: 48px;
    background: rgba(200, 150, 78, 0.1);
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .about-feature h4 {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 4px;
    color: var(--color-text);
  }

  .about-feature p {
    font-size: 0.9rem;
    margin-bottom: 0;
  }

  /* ---- PROJECT PREVIEW ---- */
  .project-preview {
    background: var(--color-bg-alt);
  }

  .project-preview__grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: var(--space-lg);
  }

  .project-card {
    position: relative;
    border-radius: var(--radius-md);
    overflow: hidden;
    cursor: pointer;
  }

  .project-card--main {
    grid-row: 1 / -1;
  }

  .project-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .project-card:hover img {
    transform: scale(1.05);
  }

  .project-card__overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: var(--space-xl);
    background: linear-gradient(transparent, rgba(0,0,0,0.7));
    color: #fff;
  }

  .project-card__tag {
    display: inline-block;
    padding: 4px 12px;
    background: var(--color-accent);
    border-radius: var(--radius-full);
    font-size: 0.75rem;
    font-weight: 600;
    margin-bottom: var(--space-sm);
  }

  .project-card__overlay h3 {
    color: #fff;
    font-size: 1.2rem;
    margin: 0;
  }

  /* ---- SERVICES ---- */
  .services__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
  }

