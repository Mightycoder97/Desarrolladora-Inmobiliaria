---
import Layout from '../layouts/Layout.astro';

const gallery = [
  { src: 'https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=800&h=600&fit=crop', alt: 'Vista aérea del proyecto', caption: 'Vista aérea' },
  { src: 'https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=800&h=600&fit=crop', alt: 'Fachada moderna', caption: 'Fachada moderna' },
  { src: 'https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?w=800&h=600&fit=crop', alt: 'Interior de sala', caption: 'Sala de estar' },
  { src: 'https://images.unsplash.com/photo-1600573472556-e636c2acda9e?w=800&h=600&fit=crop', alt: 'Cocina moderna', caption: 'Cocina equipada' },
  { src: 'https://images.unsplash.com/photo-1613490493576-7fde63acd811?w=800&h=600&fit=crop', alt: 'Vista exterior', caption: 'Exteriores' },
  { src: 'https://images.unsplash.com/photo-1600566753190-17f0baa2a6c3?w=800&h=600&fit=crop', alt: 'Jardín del proyecto', caption: 'Áreas verdes' },
];

const lots = [
  { type: 'Lote A-01', area: '90 m²', price: 'S/ 85,000', status: 'Disponible' },
  { type: 'Lote A-02', area: '90 m²', price: 'S/ 85,000', status: 'Reservado' },
  { type: 'Lote A-03', area: '120 m²', price: 'S/ 125,000', status: 'Disponible' },
  { type: 'Lote B-01', area: '120 m²', price: 'S/ 125,000', status: 'Vendido' },
  { type: 'Lote B-02', area: '200 m²', price: 'S/ 195,000', status: 'Disponible' },
  { type: 'Lote B-03', area: '200 m²', price: 'S/ 195,000', status: 'Disponible' },
  { type: 'Lote C-01', area: '150 m²', price: 'S/ 155,000', status: 'Reservado' },
  { type: 'Lote C-02', area: '150 m²', price: 'S/ 155,000', status: 'Disponible' },
];
---

<Layout
  title="Proyecto Residencial Dharsain — Dharsain Inmobiliaria"
  description="Conoce el proyecto Residencial Dharsain en Lima. Lotes desde 90m², financiamiento flexible, áreas verdes y ubicación privilegiada."
>

  <!-- PAGE HERO -->
  <section class="page-hero">
    <div class="page-hero__overlay"></div>
    <div class="container page-hero__content">
      <span class="hero__badge">Proyecto Estrella</span>
      <h1>Residencial Dharsain</h1>
      <p>Una urbanización exclusiva diseñada para familias que buscan calidad de vida en una ubicación estratégica de Lima.</p>
    </div>
  </section>

  <!-- PROJECT OVERVIEW -->
  <section class="section">
    <div class="container">
      <div class="overview-grid">
        <div class="overview-content">
          <span class="section-tag">El Proyecto</span>
          <h2>Vive donde siempre soñaste</h2>
          <p>
            Residencial Dharsain es un proyecto de urbanización que ofrece lotes de terreno
            completamente habilitados, con servicios de agua, desagüe, electricidad y pistas
            asfaltadas. Ubicado en una zona con alto potencial de crecimiento.
          </p>
          <div class="overview-features">
            <div class="overview-feat">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
              <span>Ubicación estratégica en Lima</span>
            </div>
            <div class="overview-feat">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/></svg>
              <span>Documentación 100% saneada</span>
            </div>
            <div class="overview-feat">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
              <span>Servicios básicos habilitados</span>
            </div>
            <div class="overview-feat">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              <span>Áreas verdes y zonas comunes</span>
            </div>
          </div>
        </div>
        <div class="overview-image">
          <img
            src="https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=600&h=700&fit=crop"
            alt="Vista del proyecto residencial"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- GALLERY -->
  <section class="section gallery-section" id="galeria">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Galería</span>
        <h2>Conoce cada rincón</h2>
        <p>Explora las imágenes de nuestro proyecto y visualiza tu futuro hogar.</p>
      </div>
      <div class="gallery-grid">
        {gallery.map((img, i) => (
          <div class:list={['gallery-item', { 'gallery-item--large': i === 0 }]}>
            <img src={img.src} alt={img.alt} loading="lazy" />
            <div class="gallery-item__caption">{img.caption}</div>
          </div>
        ))}
      </div>

      <!-- Video Tour -->
      <div class="video-section">
        <h3>Video Tour del Proyecto</h3>
        <div class="video-wrapper">
          <div class="video-facade" id="video-facade">
            <img
              src="https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=1200&h=675&fit=crop"
              alt="Video tour del proyecto"
              loading="lazy"
            />
            <div class="play-button">
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="white"><polygon points="5 3 19 12 5 21 5 3"/></svg>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PRICING TABLE -->
  <section class="section" id="precios" style="background: var(--color-bg-alt);">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Precios y Disponibilidad</span>
        <h2>Elige tu lote ideal</h2>
        <p>Selecciona el lote que mejor se adapte a tus necesidades y presupuesto.</p>
      </div>
      <div class="lots-table-wrapper">
        <table class="lots-table">
          <thead>
            <tr>
              <th>Lote</th>
              <th>Área</th>
              <th>Precio</th>
              <th>Estado</th>
              <th>Acción</th>
            </tr>
          </thead>
          <tbody>
            {lots.map(lot => (
              <tr>
                <td><strong>{lot.type}</strong></td>
                <td>{lot.area}</td>
                <td class="lot-price">{lot.price}</td>
                <td>
                  <span class:list={['status-badge', `status--${lot.status.toLowerCase()}`]}>
                    {lot.status}
                  </span>
                </td>
                <td>
                  {lot.status === 'Disponible' ? (
                    <a href="/#contacto" class="btn btn-primary btn-sm">Reservar</a>
                  ) : (
                    <span class="btn btn-sm" style="opacity: 0.4; cursor: not-allowed;">No disponible</span>
                  )}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- FINANCING -->
  <section class="section financing" id="financiamiento">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Financiamiento</span>
        <h2>Planes de pago flexibles</h2>
        <p>Hacemos posible tu inversión con opciones diseñadas a tu medida.</p>
      </div>
      <div class="financing-grid">
        <div class="financing-card">
          <div class="financing-card__icon">💳</div>
          <h3>Pago al Contado</h3>
          <p class="financing-discount">5% de descuento</p>
          <p>Realiza el pago total y obtén un descuento especial sobre el precio de lista.</p>
        </div>
        <div class="financing-card financing-card--featured">
          <div class="financing-card__icon">📋</div>
          <h3>Financiamiento Directo</h3>
          <p class="financing-discount">Cuota inicial desde 8%</p>
          <ul class="financing-list">
            <li>Sin evaluación crediticia</li>
            <li>Hasta 48 cuotas mensuales</li>
            <li>Tasa preferencial</li>
            <li>Sin garante</li>
          </ul>
        </div>
        <div class="financing-card">
          <div class="financing-card__icon">🏦</div>
          <h3>Crédito Hipotecario</h3>
          <p class="financing-discount">Con bancos aliados</p>
          <p>Te asesoramos para obtener los mejores términos con entidades financieras aliadas.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- LOCATION -->
  <section class="section" id="ubicacion">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Ubicación</span>
        <h2>Ubicación del proyecto</h2>
        <p>Estratégicamente ubicado con acceso a las principales vías de Lima.</p>
      </div>
      <div class="map-wrapper">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3901.964!2d-77.0428!3d-12.0464!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMTLCsDAyJzQ3LjAiUyA3N8KwMDInMzQuMSJX!5e0!3m2!1ses!2spe!4v1"
          width="100%"
          height="450"
          style="border:0; border-radius: var(--radius-md);"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Ubicación del proyecto Residencial Dharsain"
        ></iframe>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container cta-content">
      <h2>¿Listo para asegurar tu lote?</h2>
      <p>No dejes pasar esta oportunidad. Los lotes se están agotando rápidamente.</p>
      <div class="cta-actions">
        <a href="/#contacto" class="btn btn-primary">Reservar Ahora</a>
        <a href="#" class="btn btn-secondary">Descargar Brochure</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* Page Hero */
  .page-hero {
    position: relative;
    padding: calc(var(--header-height) + 60px) 0 80px;
    background-image: url('https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=1600&h=600&fit=crop');
    background-size: cover;
    background-position: center;
    text-align: center;
  }

  .page-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(15,26,46,0.92), rgba(26,39,68,0.88));
  }

  .page-hero__content {
    position: relative;
    z-index: 2;
  }

  .page-hero h1 {
    color: #fff;
    margin-bottom: var(--space-md);
  }

  .page-hero p {
    color: rgba(255,255,255,0.7);
    font-size: 1.1rem;
    max-width: 600px;
    margin: 0 auto;
  }

  .hero__badge {
    display: inline-block;
    padding: 8px 20px;
    background: rgba(200, 150, 78, 0.2);
    border: 1px solid rgba(200, 150, 78, 0.4);
    border-radius: var(--radius-full);
    color: var(--color-accent-light);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-lg);
  }

  .section-tag {
    display: inline-block;
    padding: 6px 16px;
    background: rgba(200, 150, 78, 0.12);
    color: var(--color-accent-dark);
    border-radius: var(--radius-full);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: var(--space-md);
  }

  /* Overview */
  .overview-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: var(--space-4xl);
    align-items: center;
  }

  .overview-content h2 {
    margin-bottom: var(--space-lg);
  }

  .overview-content p {
    font-size: 1.05rem;
    line-height: 1.8;
  }

  .overview-features {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    margin-top: var(--space-xl);
  }

  .overview-feat {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    color: var(--color-text-secondary);
    font-weight: 500;
  }

  .overview-feat svg {
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .overview-image img {
    width: 100%;
    height: 500px;
    object-fit: cover;
    border-radius: var(--radius-lg);
  }

  /* Gallery */
  .gallery-section {
    background: var(--color-bg-alt);
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
  }

  .gallery-item {
    position: relative;
    border-radius: var(--radius-md);
    overflow: hidden;
    cursor: pointer;
  }

  .gallery-item--large {
    grid-column: span 2;
    grid-row: span 2;
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    min-height: 200px;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .gallery-item:hover img {
    transform: scale(1.05);
  }

  .gallery-item__caption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: var(--space-md) var(--space-lg);
    background: linear-gradient(transparent, rgba(0,0,0,0.7));
    color: #fff;
    font-size: 0.9rem;
    font-weight: 500;
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .gallery-item:hover .gallery-item__caption {
    opacity: 1;
  }

  /* Video */
  .video-section {
    margin-top: var(--space-3xl);
    text-align: center;
  }

  .video-section h3 {
    margin-bottom: var(--space-xl);
  }

  .video-wrapper {
    max-width: 900px;
    margin: 0 auto;
  }

  .video-facade {
    position: relative;
    border-radius: var(--radius-md);
    overflow: hidden;
    cursor: pointer;
    aspect-ratio: 16 / 9;
  }

  .video-facade img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .play-button {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 80px;
    height: 80px;
    background: rgba(200, 150, 78, 0.9);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all var(--transition-base);
  }

  .video-facade:hover .play-button {
    transform: translate(-50%, -50%) scale(1.1);
    background: var(--color-accent);
  }

  /* Lots Table */
  .lots-table-wrapper {
    overflow-x: auto;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-md);
  }

  .lots-table {
    width: 100%;
    border-collapse: collapse;
    background: var(--color-surface);
  }

  .lots-table th {
    background: var(--color-primary);
    color: #fff;
    padding: 16px 20px;
    text-align: left;
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .lots-table td {
    padding: 16px 20px;
    border-bottom: 1px solid var(--color-border);
    font-size: 0.95rem;
  }

  .lots-table tr:hover {
    background: rgba(200, 150, 78, 0.04);
  }

  .lot-price {
    font-weight: 700;
    color: var(--color-primary);
  }

  .status-badge {
    display: inline-block;
    padding: 4px 12px;
    border-radius: var(--radius-full);
    font-size: 0.8rem;
    font-weight: 600;
  }

  .status--disponible {
    background: rgba(46, 125, 50, 0.1);
    color: var(--color-available);
  }

  .status--reservado {
    background: rgba(245, 124, 0, 0.1);
    color: var(--color-reserved);
  }

  .status--vendido {
    background: rgba(198, 40, 40, 0.1);
    color: var(--color-sold);
  }

  /* Financing */
  .financing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
  }

  .financing-card {
    background: var(--color-surface);
    border-radius: var(--radius-md);
    padding: var(--space-2xl);
    border: 1px solid var(--color-border);
    text-align: center;
    transition: all var(--transition-base);
  }

  .financing-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .financing-card--featured {
    border-color: var(--color-accent);
    box-shadow: var(--shadow-md);
  }

  .financing-card__icon {
    font-size: 2.5rem;
    margin-bottom: var(--space-md);
  }

  .financing-card h3 {
    font-family: var(--font-body);
    font-size: 1.2rem;
    font-weight: 700;
    margin-bottom: var(--space-sm);
  }

  .financing-discount {
    color: var(--color-accent);
    font-weight: 700;
    font-size: 1rem;
    margin-bottom: var(--space-md);
  }

  .financing-list {
    text-align: left;
    margin-top: var(--space-md);
  }

  .financing-list li {
    padding: 6px 0;
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    position: relative;
    padding-left: 20px;
  }

  .financing-list li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-weight: 700;
  }

  /* Map */
  .map-wrapper {
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: var(--shadow-md);
  }

  /* CTA */
  .cta-section {
    background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
    padding: var(--space-4xl) 0;
    text-align: center;
  }

  .cta-content h2 {
    color: #fff;
    margin-bottom: var(--space-md);
  }

  .cta-content p {
    color: rgba(255,255,255,0.7);
    font-size: 1.1rem;
    margin-bottom: var(--space-xl);
  }

  .cta-actions {
    display: flex;
    gap: var(--space-md);
    justify-content: center;
    flex-wrap: wrap;
  }

  @media (max-width: 768px) {
    .overview-grid {
      grid-template-columns: 1fr;
    }
    .overview-image img {
      height: 300px;
    }
    .gallery-grid {
      grid-template-columns: 1fr 1fr;
    }
    .gallery-item--large {
      grid-column: span 2;
      grid-row: auto;
    }
    .financing-grid {
      grid-template-columns: 1fr;
      max-width: 400px;
      margin: 0 auto;
    }
  }
</style>
